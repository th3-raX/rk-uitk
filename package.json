{
  "name": "rk-uitk",
  "version": "0.1.0",
  "description": "A production-grade React component library with vanilla CSS, full TypeScript support, and zero runtime dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/styles/global.css"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "build": "tsup",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "size": "size-limit",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.0.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.15",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "size-limit": "^12.0.1",
    "storybook": "^8.6.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "10 KB"
    }
  ],
  "keywords": [
    "react",
    "component-library",
    "design-system",
    "ui-kit",
    "typescript",
    "css-modules"
  ],
  "license": "MIT",
  "author": "Ravi Khatri",
  "repository": {
    "type": "git",
    "url": "https://github.com/th3-raX/rk-uitk.git"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
